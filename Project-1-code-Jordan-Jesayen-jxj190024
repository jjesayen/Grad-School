# Deterministic, stateless cleaning + feature engineering.
# Nothing here is *fit* from data, so it is safe to apply to every split and to
# the scoring/holdout file identically.
# ---------------------------------------------------------------------------
def _standardize_raw_categoricals(X):
    """Map the known-messy categorical fields to clean, finite levels."""
    X = X.copy()

    def map_yn(series):
        s = series.astype("string").str.strip().str.upper()
        out = pd.Series("MISSING", index=s.index, dtype="object")
        out[s == "Y"] = "Y"
        out[s == "N"] = "N"
        out[s == "0"] = "N"  # RevLineCr/LowDoc encode some negatives as 0
        out[s == "1"] = "Y"
        out[~s.isin(["Y", "N", "0", "1"]) & s.notna()] = "OTHER"
        return out

    if "RevLineCr" in X:
        X["RevLineCr"] = map_yn(X["RevLineCr"])
    if "LowDoc" in X:
        X["LowDoc"] = map_yn(X["LowDoc"])
    # NewExist: 1 = existing, 2 = new; 0 / NaN are invalid -> 'UNK'.
    if "NewExist" in X:
        ne = pd.to_numeric(X["NewExist"], errors="coerce")
        X["NewExist"] = np.where(ne == 1, "EXISTING", np.where(ne == 2, "NEW", "UNK"))
    # UrbanRural: 0 = undefined, 1 = urban, 2 = rural.
    if "UrbanRural" in X:
        ur = pd.to_numeric(X["UrbanRural"], errors="coerce").fillna(0).astype(int)
        X["UrbanRural"] = ur.map({0: "UNDEF", 1: "URBAN", 2: "RURAL"}).fillna("UNDEF")
    return X


def add_engineered_features(X):
    """
    Add at least 10 qualifying engineered features.
    One-hot encoded columns, label encoded columns, target encoded columns, and
    simple direct copies of existing columns do not count toward the 10 required
    engineered features. Keep this function reproducible so the same logic can
    be used in the scoring file.
    """
    X = _standardize_raw_categoricals(X)

    gross_appv = pd.to_numeric(X.get("GrAppv"), errors="coerce")
    sba_appv = pd.to_numeric(X.get("SBA_Appv"), errors="coerce")
    disb = pd.to_numeric(X.get("DisbursementGross"), errors="coerce")
    balance = pd.to_numeric(X.get("BalanceGross"), errors="coerce")
    no_emp = pd.to_numeric(X.get("NoEmp"), errors="coerce")
    create_job = pd.to_numeric(X.get("CreateJob"), errors="coerce")
    retain_job = pd.to_numeric(X.get("RetainedJob"), errors="coerce")

    eps = 1.0  # avoid divide-by-zero

    # 1. Share of the loan guaranteed by the SBA (key risk/incentive signal).
    X["sba_guarantee_ratio"] = (sba_appv / (gross_appv + eps)).clip(0, 1)
    # 2. Portion of the loan NOT guaranteed (bank's own exposure).
    X["bank_exposure_amt"] = (gross_appv - sba_appv).clip(lower=0)
    # 3. Disbursed amount relative to approved (top-ups / under-draws).
    X["disb_to_appv_ratio"] = disb / (gross_appv + eps)
    # 4. Approved dollars per employee (leverage per worker).
    X["appv_per_employee"] = gross_appv / (no_emp + eps)
    # 5. Total jobs touched (created + retained).
    X["total_jobs"] = (create_job.fillna(0) + retain_job.fillna(0))
    # 6. Approved dollars per total job.
    X["appv_per_job"] = gross_appv / (X["total_jobs"] + eps)
    # 7. Log-scaled approved amount (tames heavy right skew for a linear model).
    X["log_gross_appv"] = np.log1p(gross_appv.clip(lower=0))
    # 8. Log-scaled disbursement.
    X["log_disbursement"] = np.log1p(disb.clip(lower=0))
    # 9. Outstanding balance present (data-quality / seasoning signal).
    X["has_outstanding_balance"] = (balance.fillna(0) > 0).astype(int)
    # 10. Borrower and lender in the same state (local-lending signal).
    same_state = (
        X.get("State", pd.Series(index=X.index)).astype("string").str.upper()
        == X.get("BankState", pd.Series(index=X.index)).astype("string").str.upper()
    )
    X["same_state_lender"] = same_state.fillna(False).astype(int)
    # 11. 2-digit NAICS sector (industry grouping; not a copy of raw NAICS).
    naics = pd.to_numeric(X.get("NAICS"), errors="coerce").fillna(0).astype("int64")
    X["naics_sector"] = (naics // 10000).astype(int).astype(str).replace("0", "UNK")
    # 12. Franchise business flag (codes 0/1 mean "not a franchise").
    fran = pd.to_numeric(X.get("FranchiseCode"), errors="coerce").fillna(0)
    X["is_franchise"] = (fran > 1).astype(int)
    # 13. Created any new jobs.
    X["creates_jobs"] = (create_job.fillna(0) > 0).astype(int)
    # 14. Large employer flag.
    X["is_large_employer"] = (no_emp.fillna(0) >= 50).astype(int)
    # 15. Gross-approval size bucket (ordinal).
    X["appv_size_bucket"] = pd.cut(
        gross_appv.fillna(0),
        bins=[-1, 50_000, 150_000, 350_000, 1_000_000, np.inf],
        labels=[0, 1, 2, 3, 4],
    ).astype("float").fillna(0).astype(int)

    return X


# ---------------------------------------------------------------------------
# Fitted preprocessing. Imputers / encoders / scaler are learned on TRAIN ONLY
# and returned in an artifacts dict, then applied unchanged to valid/test/score.
# ---------------------------------------------------------------------------
def _smoothed_target_encoding(series, y, global_mean, smoothing=50.0):
    """Return a {level: encoded_value} map using additive (Bayesian) smoothing."""
    s = series.astype("string").fillna("MISSING")
    stats = pd.DataFrame({"level": s.values, "y": y.values}).groupby("level")["y"]
    counts = stats.count()
    means = stats.mean()
    encoded = (counts * means + smoothing * global_mean) / (counts + smoothing)
    return encoded.to_dict()


def clean_and_prepare_train(X_train, y_train):
    """
    Fit training-only cleaning and preprocessing objects.
    Examples include imputers, categorical encoders, WOE/target encoders, and
    scalers. Fit these objects on Train only. Return transformed Train data
    plus a dictionary of fitted artifacts needed for Validation, Test, and
    scoring.
    """
    y_train = pd.Series(np.asarray(y_train).astype(int), index=X_train.index)

    # Partition columns by type/cardinality.
    numeric_cols, low_card_cols, high_card_cols = [], [], []
    for col in X_train.columns:
        if pd.api.types.is_numeric_dtype(X_train[col]):
            numeric_cols.append(col)
        elif X_train[col].nunique(dropna=True) <= LOW_CARD_MAX_LEVELS:
            low_card_cols.append(col)
        else:
            high_card_cols.append(col)

    # Numeric: median impute (fit) then standardize (fit).
    medians = {c: float(pd.to_numeric(X_train[c], errors="coerce").median()) for c in numeric_cols}
    means, stds = {}, {}
    for c in numeric_cols:
        col = pd.to_numeric(X_train[c], errors="coerce").fillna(medians[c])
        means[c] = float(col.mean())
        std = float(col.std())
        stds[c] = std if std > 1e-12 else 1.0

    # Low-cardinality categoricals: store level lists for stable one-hot.
    onehot_levels = {
        c: sorted(X_train[c].astype("string").fillna("MISSING").unique().tolist())
        for c in low_card_cols
    }

    # High-cardinality categoricals: smoothed target encoding.
    global_mean = float(y_train.mean())
    target_maps = {
        c: _smoothed_target_encoding(X_train[c], y_train, global_mean)
        for c in high_card_cols
    }

    artifacts = {
        "numeric_cols": numeric_cols,
        "low_card_cols": low_card_cols,
        "high_card_cols": high_card_cols,
        "medians": medians,
        "means": means,
        "stds": stds,
        "onehot_levels": onehot_levels,
        "target_maps": target_maps,
        "global_mean": global_mean,
    }

    X_train_processed = apply_cleaning_and_preprocessing(X_train, artifacts)
    artifacts["feature_order"] = X_train_processed.columns.tolist()
    return X_train_processed, artifacts


def apply_cleaning_and_preprocessing(X, preprocessing_artifacts):
    """
    Apply fitted preprocessing objects to Validation, Test, or scoring data.
    Use transform-style behavior only. Do not fit anything here.
    """
    a = preprocessing_artifacts
    frames = []

    # Numeric: impute with train medians, scale with train mean/std.
    num = {}
    for c in a["numeric_cols"]:
        col = pd.to_numeric(X[c], errors="coerce").fillna(a["medians"][c]) if c in X else \
            pd.Series(a["medians"][c], index=X.index)
        num[c] = (col - a["means"][c]) / a["stds"][c]
    if num:
        frames.append(pd.DataFrame(num, index=X.index))

    # Low-cardinality: one-hot against train levels (unknown -> all zeros).
    for c in a["low_card_cols"]:
        s = X[c].astype("string").fillna("MISSING") if c in X else \
            pd.Series("MISSING", index=X.index)
        oh = {f"{c}__{lvl}": (s == lvl).astype(int) for lvl in a["onehot_levels"][c]}
        frames.append(pd.DataFrame(oh, index=X.index))

    # High-cardinality: map through train target-encoding (unseen -> global mean).
    te = {}
    for c in a["high_card_cols"]:
        s = X[c].astype("string").fillna("MISSING") if c in X else \
            pd.Series("MISSING", index=X.index)
        te[c + "__te"] = s.map(a["target_maps"][c]).fillna(a["global_mean"]).astype(float)
    if te:
        frames.append(pd.DataFrame(te, index=X.index))

    out = pd.concat(frames, axis=1)
    out = out.replace([np.inf, -np.inf], 0.0).fillna(0.0)

    # Guarantee identical column set/order once feature_order is known.
    if "feature_order" in a:
        out = out.reindex(columns=a["feature_order"], fill_value=0.0)
    return out


def tune_sklearn_logistic_regression(X_train, y_train, X_valid, y_valid):
    """
    Train and tune sklearn Logistic Regression variants.
    Requirements:
    - evaluate at least 50 hyperparameter combinations;
    - use AUCPR or Log-loss for tuning/model selection;
    - keep the Test set locked until final evaluation.
    """
    y_train = np.asarray(y_train).astype(int)
    y_valid = np.asarray(y_valid).astype(int)

    Cs = [0.001, 0.01, 0.1, 1.0, 10.0, 100.0]
    class_weights = [None, "balanced"]

    # Build the hyperparameter grid: l2, l1, and elasticnet (3 l1_ratios).
    # 6 C x 2 cw x (1 + 1 + 3) = 60 combinations (>= 50 required).
    grid = []
    for C in Cs:
        for cw in class_weights:
            grid.append({"penalty": "l2", "C": C, "class_weight": cw})
            grid.append({"penalty": "l1", "C": C, "class_weight": cw})
            for r in (0.2, 0.5, 0.8):
                grid.append(
                    {"penalty": "elasticnet", "C": C, "l1_ratio": r, "class_weight": cw}
                )

    if MAX_COMBOS:  # smoke-test cap only
        grid = grid[:MAX_COMBOS]

    results = []
    best = {"aucpr": -np.inf, "model": None, "params": None}
    print(f"\n=== sklearn LogisticRegression: {len(grid)} combinations ===")
    for i, params in enumerate(grid, 1):
        model = LogisticRegression(
            solver="saga",
            penalty=params["penalty"],
            C=params["C"],
            l1_ratio=params.get("l1_ratio"),
            class_weight=params["class_weight"],
            max_iter=200,
            tol=1e-3,
            n_jobs=-1,
            random_state=RANDOM_STATE,
        )
        model.fit(X_train, y_train)
        p_valid = model.predict_proba(X_valid)[:, 1]
        aucpr = average_precision_score(y_valid, p_valid)
        ll = log_loss(y_valid, p_valid)
        results.append(
            {
                "penalty": params["penalty"],
                "C": params["C"],
                "l1_ratio": params.get("l1_ratio"),
                "class_weight": str(params["class_weight"]),
                "valid_aucpr": aucpr,
                "valid_log_loss": ll,
            }
        )
        if aucpr > best["aucpr"]:
            best = {"aucpr": aucpr, "model": model, "params": params}
        if i % 10 == 0 or i == len(grid):
            print(f"  [{i}/{len(grid)}] best valid AUCPR so far: {best['aucpr']:.4f}")

    results_df = pd.DataFrame(results).sort_values("valid_aucpr", ascending=False)
    return {
        "model": best["model"],
        "params": best["params"],
        "valid_aucpr": best["aucpr"],
        "results": results_df,
    }


def tune_h2o_glm(X_train, y_train, X_valid, y_valid):
    """
    Train and tune H2O-3 GLM binomial variants.
    Use bounded H2O initialization unless the instructor approves another setup:
        h2o.init(name="ML_Project_Cluster", max_mem_size="4G", nthreads=4, verbose=False)
    Requirements:
    - evaluate at least 50 hyperparameter combinations;
    - use AUCPR or Log-loss for tuning/model selection;
    - keep the Test set locked until final evaluation.
    """
    if not (H2O_AVAILABLE and RUN_H2O):
        print(
            "\n=== H2O GLM: SKIPPED ===\n"
            "  H2O is not available in this environment (or PROJECT1_RUN_H2O=0). "
            "Install h2o and re-run to train the GLM grid."
        )
        return None

    h2o.init(name="ML_Project_Cluster", max_mem_size="4G", nthreads=4, verbose=False)

    # Assemble labeled H2O frames. Target must be a factor for binomial GLM.
    train_df = X_train.copy()
    train_df[TARGET_COL] = np.asarray(y_train).astype(int)
    valid_df = X_valid.copy()
    valid_df[TARGET_COL] = np.asarray(y_valid).astype(int)

    htrain = h2o.H2OFrame(train_df)
    hvalid = h2o.H2OFrame(valid_df)
    htrain[TARGET_COL] = htrain[TARGET_COL].asfactor()
    hvalid[TARGET_COL] = hvalid[TARGET_COL].asfactor()
    features = [c for c in X_train.columns]

    # Grid: 5 alphas x 11 lambdas = 55 combinations (>= 50 required).
    alphas = [0.0, 0.25, 0.5, 0.75, 1.0]
    lambdas = [10 ** p for p in np.linspace(-6, -1, 11)]
    hyper_params = {"alpha": alphas, "lambda": [float(l) for l in lambdas]}
    if MAX_COMBOS:
        hyper_params["lambda"] = hyper_params["lambda"][: max(1, MAX_COMBOS // len(alphas))]

    grid = H2OGridSearch(
        model=H2OGeneralizedLinearEstimator(
            family="binomial",
            lambda_search=False,
            standardize=True,
            seed=RANDOM_STATE,
        ),
        hyper_params=hyper_params,
        grid_id="glm_grid_project1",
    )
    n_combos = len(alphas) * len(hyper_params["lambda"])
    print(f"\n=== H2O GLM: {n_combos} combinations ===")
    grid.train(x=features, y=TARGET_COL, training_frame=htrain, validation_frame=hvalid)

    # Select on validation AUCPR.
    sorted_grid = grid.get_grid(sort_by="aucpr", decreasing=True)
    best_model = sorted_grid.models[0]
    valid_aucpr = best_model.aucpr(valid=True)
    print(f"  best valid AUCPR: {valid_aucpr:.4f}")

    rows = []
    for m in sorted_grid.models:
        rows.append(
            {
                "alpha": m.actual_params.get("alpha"),
                "lambda": m.actual_params.get("lambda"),
                "valid_aucpr": m.aucpr(valid=True),
                "valid_log_loss": m.logloss(valid=True),
            }
        )
    return {
        "model": best_model,
        "valid_aucpr": valid_aucpr,
        "results": pd.DataFrame(rows),
        "features": features,
    }


def find_best_f1_threshold(y_true, probability_1):
    """Search thresholds and return the threshold with the best F1 score."""
    thresholds = np.linspace(0.01, 0.99, 99)
    best_threshold = None
    best_f1 = -np.inf
    for threshold in thresholds:
        labels = (probability_1 >= threshold).astype(int)
        score = f1_score(y_true, labels, average="macro")
        if score > best_f1:
            best_f1 = score
            best_threshold = threshold
    return best_threshold, best_f1


def evaluate_binary_model(y_true, probability_1, threshold):
    """Return required binary-classification metrics for the report."""
    probability_0 = 1 - probability_1
    labels = (probability_1 >= threshold).astype(int)
    return {
        "auc": roc_auc_score(y_true, probability_1),
        "aucpr": average_precision_score(y_true, probability_1),
        "log_loss": log_loss(y_true, np.column_stack([probability_0, probability_1])),
        "confusion_matrix": confusion_matrix(y_true, labels),
    }


def summarize_coefficients(model, feature_names):
    """
    Create coefficient evidence for the Markdown report.
    Include enough information to identify top positive and negative
    coefficients and to explain how preprocessing, encoding, scaling, and
    engineered features affect interpretation.
    """
    coefs = np.asarray(model.coef_).ravel()
    intercept = float(np.asarray(model.intercept_).ravel()[0])
    df = pd.DataFrame({"feature": feature_names, "coefficient": coefs})
    df["odds_ratio"] = np.exp(df["coefficient"])
    df["abs_coefficient"] = df["coefficient"].abs()
    df = df.sort_values("coefficient", ascending=False).reset_index(drop=True)

    summary = {
        "intercept": intercept,
        "n_features": int(len(feature_names)),
        "n_nonzero": int((df["coefficient"] != 0).sum()),
        "top_positive": df.head(15),
        "top_negative": df.tail(15).iloc[::-1],
    }
    # Note for the report: features were standardized (numeric) / target- or
    # one-hot-encoded, so coefficients are on a comparable scale and represent
    # the change in log-odds of default per 1-SD (numeric) or per category.
    print("\n=== TOP POSITIVE COEFFICIENTS (push toward default) ===")
    print(summary["top_positive"].to_string(index=False))
    print("\n=== TOP NEGATIVE COEFFICIENTS (push toward repayment) ===")
    print(summary["top_negative"].to_string(index=False))
    return summary, df


# Module-level holder so save_artifacts / save_report_outputs (which the
