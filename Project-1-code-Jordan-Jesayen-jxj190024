def _h2o_predict_proba(model, X):
    """Return P(default=1) from a fitted H2O binomial model for frame X."""
    hf = h2o.H2OFrame(X)
    preds = model.predict(hf).as_data_frame()
    # H2O binomial output has a 'p1' column = P(class==1).
    return preds["p1"].to_numpy()


def main():
    ensure_output_dirs()
    df = load_training_data()
    # Complete each step below. Keep the Test set locked until final evaluation.
    run_data_quality_checks(df)
    X_train, X_valid, X_test, y_train, y_valid, y_test = split_data(df)

    # 1) Feature engineering (deterministic, applied to every split identically).
    X_train_fe = add_engineered_features(X_train)
    X_valid_fe = add_engineered_features(X_valid)
    X_test_fe = add_engineered_features(X_test)

    # 2) Fit preprocessing on TRAIN ONLY, then transform valid/test.
    X_train_p, preprocessing = clean_and_prepare_train(X_train_fe, y_train)
    X_valid_p = apply_cleaning_and_preprocessing(X_valid_fe, preprocessing)
    X_test_p = apply_cleaning_and_preprocessing(X_test_fe, preprocessing)
    feature_names = preprocessing["feature_order"]
    _STATE["preprocessing"] = preprocessing

    # 3) Tune sklearn Logistic Regression (Test stays locked).
    sk = tune_sklearn_logistic_regression(X_train_p, y_train, X_valid_p, y_valid)
    _STATE["sklearn_model"] = sk["model"]
    _STATE["sklearn_results"] = sk["results"]

    # 4) Tune H2O GLM (optional / when installed).
    h2o_res = tune_h2o_glm(X_train_p, y_train, X_valid_p, y_valid)
    _STATE["h2o_model"] = h2o_res["model"] if h2o_res else None
    _STATE["h2o_results"] = h2o_res["results"] if h2o_res else None

    # 5) Pick the final model by VALIDATION AUCPR (Test still locked).
    candidates = {"sklearn_logreg": sk["valid_aucpr"]}
    if h2o_res:
        candidates["h2o_glm"] = h2o_res["valid_aucpr"]
    final_name = max(candidates, key=candidates.get)
    _STATE["final_model_name"] = final_name
    print(f"\n=== MODEL SELECTION (by valid AUCPR) ===\n  {candidates}\n  -> {final_name}")

    # Validation probabilities of the chosen model -> tune F1 threshold on VALID.
    if final_name == "sklearn_logreg":
        p_valid = sk["model"].predict_proba(X_valid_p)[:, 1]
    else:
        p_valid = _h2o_predict_proba(h2o_res["model"], X_valid_p)
    threshold, valid_f1 = find_best_f1_threshold(np.asarray(y_valid).astype(int), p_valid)
    _STATE["threshold"] = threshold
    print(f"  chosen decision threshold (max macro-F1 on valid): {threshold:.2f} (F1={valid_f1:.4f})")

    # 6) FINAL, one-time evaluation on the locked Test set.
    if final_name == "sklearn_logreg":
        p_test = sk["model"].predict_proba(X_test_p)[:, 1]
    else:
        p_test = _h2o_predict_proba(h2o_res["model"], X_test_p)
    test_metrics = evaluate_binary_model(np.asarray(y_test).astype(int), p_test, threshold)
    _STATE["test_metrics"] = test_metrics
    print("\n=== FINAL TEST METRICS ===")
    print(f"  AUC     : {test_metrics['auc']:.4f}")
    print(f"  AUCPR   : {test_metrics['aucpr']:.4f}")
    print(f"  LogLoss : {test_metrics['log_loss']:.4f}")
    print(f"  Confusion matrix:\n{test_metrics['confusion_matrix']}")

    # 7) Coefficient interpretation (sklearn linear model).
    coef_summary, coef_table = summarize_coefficients(sk["model"], feature_names)
    _STATE["coef_summary"] = coef_summary
    _STATE["coef_table"] = coef_table

    # 8) Build a tidy metric summary across splits for the report.
    rows = []
    for split_name, Xp, yv in [
        ("train", X_train_p, y_train),
        ("valid", X_valid_p, y_valid),
        ("test", X_test_p, y_test),
    ]:
        if final_name == "sklearn_logreg":
            p = sk["model"].predict_proba(Xp)[:, 1]
        else:
            p = _h2o_predict_proba(h2o_res["model"], Xp)
        m = evaluate_binary_model(np.asarray(yv).astype(int), p, threshold)
        rows.append(
            {
                "model": final_name,
                "split": split_name,
                "auc": m["auc"],
                "aucpr": m["aucpr"],
                "log_loss": m["log_loss"],
                "threshold": threshold,
            }
        )
    _STATE["metrics_table"] = pd.DataFrame(rows)

    # 9) Persist scoring artifacts and report outputs.
    save_artifacts()
    save_report_outputs()
    print("\nDone. Final model:", final_name)


if __name__ == "__main__":
    main()
