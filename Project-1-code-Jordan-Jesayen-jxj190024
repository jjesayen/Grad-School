_STATE = {}


def save_artifacts():
    """
    Save all artifacts required by your scoring file.
    Include trained models, preprocessing objects, feature lists, feature order,
    thresholds, and any model-specific metadata needed to reproduce scoring.
    Use relative paths under artifacts/.
    """
    ensure_output_dirs()

    # Preprocessing objects + feature order (everything the scoring file needs).
    with open(ARTIFACTS_DIR / "preprocessing.pkl", "wb") as fh:
        pickle.dump(_STATE["preprocessing"], fh)

    # Final selected model.
    final_name = _STATE["final_model_name"]
    if final_name == "sklearn_logreg":
        with open(ARTIFACTS_DIR / "final_model_sklearn.pkl", "wb") as fh:
            pickle.dump(_STATE["sklearn_model"], fh)
    elif final_name == "h2o_glm" and H2O_AVAILABLE:
        h2o.save_model(_STATE["h2o_model"], path=str(ARTIFACTS_DIR), force=True)

    # Also persist the sklearn model whenever it exists (useful fallback).
    if _STATE.get("sklearn_model") is not None:
        with open(ARTIFACTS_DIR / "final_model_sklearn.pkl", "wb") as fh:
            pickle.dump(_STATE["sklearn_model"], fh)

    metadata = {
        "final_model_name": final_name,
        "decision_threshold": float(_STATE["threshold"]),
        "feature_order": _STATE["preprocessing"].get("feature_order", []),
        "target_col": TARGET_COL,
        "random_state": RANDOM_STATE,
        "engineered_feature_note": (
            "Apply add_engineered_features(), then "
            "apply_cleaning_and_preprocessing(X, preprocessing) before predicting."
        ),
    }
    with open(ARTIFACTS_DIR / "model_metadata.json", "w") as fh:
        json.dump(metadata, fh, indent=2)
    print(f"\nSaved artifacts to {ARTIFACTS_DIR}")


