def _resolve_train_path():
    """
    Robustly locate the training CSV.

    The template expects ``data/SBA_loans_project_1.csv.zip`` but the file may
    be a plain ``.csv`` (optionally with a trailing " 2" added by the OS), and
    it may sit in the project root rather than ``data/``. Try the documented
    path first, then fall back to any reasonable match so the script runs as-is.
    """
    if TRAIN_DATA_PATH.exists():
        return TRAIN_DATA_PATH
    candidates = []
    for folder in (DATA_DIR, PROJECT_ROOT):
        if folder.exists():
            candidates += sorted(folder.glob("SBA_loans_project_1*.csv*"))
    # Prefer labeled training files, exclude the unlabeled holdout export.
    candidates = [c for c in candidates if "holdout" not in c.name.lower()]
    if not candidates:
        raise FileNotFoundError(
            f"Could not find the training data. Looked for {TRAIN_DATA_PATH} and "
            f"SBA_loans_project_1*.csv* under {DATA_DIR} and {PROJECT_ROOT}."
        )
    return candidates[0]


def load_training_data():
    """Load the labeled Project 1 training data."""
    path = _resolve_train_path()
    df = pd.read_csv(path, low_memory=False)
    # Drop a pure row-id column if present; it carries no signal.
    for id_col in ("index", "Unnamed: 0"):
        if id_col in df.columns:
            df = df.drop(columns=[id_col])
    if SAMPLE_N is not None and SAMPLE_N < len(df):
        df = df.sample(n=SAMPLE_N, random_state=RANDOM_STATE).reset_index(drop=True)
    return df


def run_data_quality_checks(df):
    """
    Inspect missingness, types, invalid values, and target distribution.
    Save or print the checks that support your report. Do not fit learned
    transformations in this function.
    """
    print("\n=== DATA QUALITY CHECKS ===")
    print(f"Rows: {len(df):,}  Columns: {df.shape[1]}")

    # Missingness.
    missing = df.isna().sum()
    missing = missing[missing > 0].sort_values(ascending=False)
    missing_pct = (missing / len(df) * 100).round(2)
    missing_tbl = pd.DataFrame({"n_missing": missing, "pct_missing": missing_pct})
    print("\nColumns with missing values:")
    print(missing_tbl if not missing_tbl.empty else "  (none)")

    # Dtypes.
    print("\nColumn dtypes:")
    print(df.dtypes)

    # Target distribution.
    print(f"\nTarget '{TARGET_COL}' distribution:")
    counts = df[TARGET_COL].value_counts(dropna=False)
    rates = (counts / len(df) * 100).round(3)
    print(pd.DataFrame({"count": counts, "pct": rates}))

    # Suspicious / invalid values worth flagging in the report.
    flags = {}
    if "DisbursementGross" in df:
        flags["disbursement_le_0"] = int((df["DisbursementGross"] <= 0).sum())
    if "GrAppv" in df:
        flags["grappv_le_0"] = int((df["GrAppv"] <= 0).sum())
    if {"SBA_Appv", "GrAppv"}.issubset(df.columns):
        flags["sba_gt_gross_approved"] = int((df["SBA_Appv"] > df["GrAppv"]).sum())
    if "NewExist" in df:
        flags["newexist_invalid_0"] = int((df["NewExist"] == 0).sum())
    if "NAICS" in df:
        flags["naics_zero_or_missing"] = int((df["NAICS"] <= 0).sum())
    print("\nInvalid / suspicious value counts:")
    print(json.dumps(flags, indent=2))

    # Persist a compact summary for the report.
    ensure_output_dirs()
    missing_tbl.to_csv(ARTIFACTS_DIR / "data_quality_missingness.csv")
    with open(ARTIFACTS_DIR / "data_quality_flags.json", "w") as fh:
